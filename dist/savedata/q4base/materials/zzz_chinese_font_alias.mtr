// 自动生成（export_font.py）：同源字体家族共享贴图的材质别名
// 引擎按 fontName 拼材质名（fonts/chinese/<家族>_<页>.tga），
// 显式 decl 优先于隐式生成，map 指向本尊家族贴图 → 显存/磁盘只留一份

fonts/chinese/chain_12.tga
{
	{
		blend blend
		colored
		map "fonts/chinese/chain_12.tga"
		clamp
		nopicmip
		forceHighQuality
	}
}
