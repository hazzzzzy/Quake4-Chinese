lipSync vo_3_1_3_180_2
{
	description	"Greetings, Corporal Rhodes. You must locate the security interfaces. There is one at the top of each tower that must be disabled to gain access to the Core. But be careful, only Corporal Kane can access them."
	text		"#str_380220"
}

