lipSync vo_3_1_3_90_1
{
	description	"Nothing's slowing it down!"
	text		"#str_380230"
}

lipSync vo_3_1_4_80_1
{
	description	"Well done, Corporal Kane! The Core security interface from Data Storage is disabled. Corporal Rhodes, you should remain there and guard the console in case the Strogg should attempt to reactivate it. Corporal Kane should locate the tram and take it to the Data Processing Tower. There he will have to deactivate the second security station at the top. Strauss out."
	text		"#str_380231"
}

lipSync vo_3_1_2_125_1
{
	description	"HQ, this Cobra squad. We've just taken level five and we are continuing to advance."
	text		"#str_380232"
}

lipSync vo_3_1_2_180_1
{
	description	"Kane, this is Hollenbeck. Good job, the TSD's are being redeployed. Now get back up here on the double."
	text		"#str_380233"
}

